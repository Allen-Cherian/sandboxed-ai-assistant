# ---------------------------------------------------------------------------
# Sandboxed AI Assistant — configuration template
#
# Copy this file to `.env`:   cp .env.example .env
#
# V1 is FULLY LOCAL and needs NO credentials. This file exists to demonstrate
# the scoped-secret/config pattern and to let you tune behavior. Every value
# below is optional and has a safe default.
#
# SECURITY: never commit your real `.env`. It is git-ignored and docker-ignored.
# Secret values (if you ever add any) are redacted from logs automatically.
# ---------------------------------------------------------------------------

# --- Environment ---
APP_ENV=production
LOG_LEVEL=INFO

# --- Filesystem boundary ---
# The ONLY directory the app may write to (inside the container). Leave default.
DATA_DIR=/app/data
LOG_DIR=/app/logs

# --- Upload policy ---
ALLOWED_EXTENSIONS=.txt,.md,.pdf
MAX_UPLOAD_MB=10

# --- Retrieval / embeddings (all local) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=4

# --- Future (NOT used in V1; shown to illustrate the secret pattern) ---
# If a credentialed provider is ever added, it would be set here and would be
# redacted from logs automatically. Leave blank for V1.
# LLM_API_KEY=
