# ---------------------------------------------------------------------------
# Sandboxed AI Assistant — configuration template
#
# Copy this file to `.env`:   cp .env.example .env
#
# V1 is FULLY LOCAL and needs NO credentials. This file exists to demonstrate
# the scoped-secret/config pattern and to let you tune behavior. Every value
# below is optional and has a safe default.
#
# SECURITY: never commit your real `.env`. It is git-ignored and docker-ignored.
# Secret values (if you ever add any) are redacted from logs automatically.
# ---------------------------------------------------------------------------

# --- Environment ---
APP_ENV=production
LOG_LEVEL=INFO

# --- Filesystem boundary ---
# The ONLY directory the app may write to (inside the container). Leave default.
DATA_DIR=/app/data
LOG_DIR=/app/logs

# --- Upload policy ---
ALLOWED_EXTENSIONS=.txt,.md,.pdf
MAX_UPLOAD_MB=10

# --- Retrieval / embeddings (all local) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=4

# --- Optional local LLM answering (default OFF = fully-local extractive mode) ---
# When LLM_ENABLED=false the app behaves exactly like V1 (no model, no network).
# To enable written answers, install Ollama on your host and pull a model:
#     brew install ollama        # or download from https://ollama.com
#     ollama pull llama3.2:1b
# then set LLM_ENABLED=true and restart.
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:1b
# The ONLY network destination the app may call. host.docker.internal = your Mac.
LLM_BASE_URL=http://host.docker.internal:11434
LLM_TIMEOUT_S=30
LLM_MAX_TOKENS=512

# --- Future API providers (NOT implemented; slot reserved) ---
# To use Claude/OpenAI later: set LLM_PROVIDER=anthropic|openai and provide a key
# below. The key is read by config.py and auto-redacted from logs. NOTE: an API
# provider sends document text off-machine — a deliberate opt-in. See
# docs/phase_llm_plan.md §10.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
